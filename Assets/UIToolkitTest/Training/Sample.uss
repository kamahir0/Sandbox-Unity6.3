/* 縦並びの全体レイアウト */
.sample-container {
    padding: 16px;
    flex-direction: column;
    align-items: stretch; /* 子要素を横幅いっぱいに広げる */
}

/* Sample.uxml 固有のスタイル */
.button-row {
    flex-direction: row;
    justify-content: space-around;
    width: 100%;
    /* flex-grow: 1; を削除して縦に広がらないように修正 */
}

/* コンテナ内のボタンを同サイズにする設定 */
.button-row > .button-standard {
    flex-grow: 1;
    flex-basis: 0;
    min-width: 0; /* 文字が溢れても縮むように設定 */
}
