/* 縦並びの全体レイアウト */
.sample-container {
    padding: 16px;
    flex-direction: column;
    align-items: stretch; /* 子要素を横幅いっぱいに広げる */
}

/* Sample.uxml 固有のスタイル */
.button-row {
    flex-direction: row;
    width: 100%;
    column-gap: 16px; /* ボタン間の隙間を少し広げた */
    margin-top: 16px;
    padding: 8px; /* コンテナ内の余白 */
}

/* ボタンを同サイズで横幅いっぱいに広げる */
.button-row > .c-button {
    flex-grow: 1;
    flex-basis: 0;
    min-width: 0;
}
