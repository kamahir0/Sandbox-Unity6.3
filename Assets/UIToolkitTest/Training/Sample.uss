/* 縦並びの全体レイアウト */
.sample-container {
    padding: 16px;
    flex-direction: column;
    align-items: stretch; /* 子要素を横幅いっぱいに広げる */
}

/* Sample.uxml 固有のスタイル */
.button-row {
    flex-direction: row;
    width: 100%;
}

/* ボタンを同サイズで横幅いっぱいに広げる */
.button-row > .c-button {
    flex-grow: 1;
    flex-basis: 0;
    min-width: 0;
}
