<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:debug="Lilja.DebugUI" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <debug:DebugMenuRoot>
        <debug:DebugMenuWindow label="All Controls Sample" style="width: 700px; max-width: 90%;">
            <debug:DebugPage>
                <debug:DebugLabel text="─── Basic Fields ───"/>
                <debug:DebugTextField label="Text Field" value="Hello World"/>
                <debug:DebugIntegerField label="Integer Field" value="42"/>
                <debug:DebugLongField label="Long Field" value="1234567890"/>
                <debug:DebugFloatField label="Float Field" value="3.14"/>
                <debug:DebugDoubleField label="Double Field" value="3.14159265"/>

                <debug:DebugLabel text="─── Sliders ───"/>
                <debug:DebugSlider label="Slider" low-value="0" high-value="1" value="0.5"/>
                <debug:DebugSliderInt label="Slider Int" low-value="0" high-value="10" value="5"/>
                <debug:DebugMinMaxSlider label="MinMax Slider" low-limit="0" high-limit="100" value="20,80"/>

                <debug:DebugLabel text="─── Progress ───"/>
                <debug:DebugProgressBar title="Health" value="75" low-value="0" high-value="100"/>

                <debug:DebugLabel text="─── Enum &amp; Selection ───"/>
                <!-- EnumField は UXML から初期化する場合 type 指定が必要になる場合がありますが、
                     ここでは要素の存在確認として配置します -->
                <debug:DebugEnumField label="Enum Field"/>
                <debug:DebugRadioButtonGroup label="Radio Group" choices="Option A,Option B,Option C"/>
                <debug:DebugToggleGroup label="Toggle Group">
                    <debug:DebugToggleGroupItem label="Item 1"/>
                    <debug:DebugToggleGroupItem label="Item 2"/>
                </debug:DebugToggleGroup>

                <debug:DebugLabel text="─── Vector Fields ───"/>
                <debug:DebugVector2Field label="Vector2" value="1,2"/>
                <debug:DebugVector2IntField label="Vector2Int" value="10,20"/>
                <debug:DebugVector3Field label="Vector3" value="1,2,3"/>
                <debug:DebugVector3IntField label="Vector3Int" value="10,20,30"/>
                <debug:DebugVector4Field label="Vector4" value="1,2,3,4"/>

                <debug:DebugLabel text="─── Rect &amp; Bounds ───"/>
                <debug:DebugRectField label="Rect" value="0,0,100,100"/>
                <debug:DebugRectIntField label="RectInt" value="0,0,100,100"/>
                <debug:DebugBoundsField label="Bounds" center="0,0,0" size="1,1,1"/>
                <debug:DebugBoundsIntField label="BoundsInt" center="0,0,0" size="10,10,10"/>

                <debug:DebugLabel text="─── Special Fields ───"/>
                <debug:DebugHash128Field label="Hash128"/>

                <debug:DebugLabel text="─── Layouts ───"/>
                <debug:DebugFoldout text="Foldout Section">
                    <debug:DebugLabel text="Inside Foldout"/>
                    <debug:DebugButton text="Child Button"/>
                </debug:DebugFoldout>

                <ui:VisualElement style="flex-direction: row; margin-top: 12px; gap: 8px;">
                    <debug:DebugSecondaryButton text="Secondary" style="flex-grow: 1;"/>
                    <debug:DebugButton text="Primary" style="flex-grow: 1;"/>
                    <debug:DebugDangerButton text="Danger" style="flex-grow: 1;"/>
                </ui:VisualElement>
            </debug:DebugPage>
        </debug:DebugMenuWindow>
    </debug:DebugMenuRoot>
</ui:UXML>
